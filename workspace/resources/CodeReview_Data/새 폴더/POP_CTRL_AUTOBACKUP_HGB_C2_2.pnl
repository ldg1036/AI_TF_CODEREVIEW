"layoutAlignment" "AlignCenter"
"dashclr"N "_Transparent"
"antiAliased" "0"
E "main()
{
  dyn_float dreturnf;
  dyn_string dreturns;
  string euhi,eulo,err_msg,all_err_msg;
  float dp_hh,dp_hi,dp_lo,dp_ll,alm_value,alm_chg_value;
  dyn_float dyn_dp_alm_value,dyn_cur_alm_value,dyn_chg_alm_value;
  dyn_string dyn_sort_cur_alm_value,dyn_obj,dyn_error_msg;
  int error_idx;
  mapping map_sort_alm_value;
  bool bitstart, bithold, bitalmreset, bitcancel;
  bool abstart, errsel, selstat, dpstat;
  string obj_name;


/////////////////////////////hz set

  float hz_val1;

  getValue(OBJ_HZ_SET1,\"text\",hz_val1);

  if(0 > hz_val1 || hz_val1 > 60)
  {
    err_msg = \"м ңм•ҪмЎ°кұҙмң„л°ҳ: Set Hz лІ”мң„ (0~60). \\n\";
    dynAppend(dyn_error_msg,err_msg);
  }

/////////////////////////////vibration set

  float vib_hilm_val1;

  getValue(OBJ_FAN_VIB_HILM,\"text\",vib_hilm_val1);

  if(-99999 > vib_hilm_val1 || vib_hilm_val1 > 99999)
  {
    err_msg = \"м ңм•ҪмЎ°кұҙмң„л°ҳ: Vibration Limit лІ”мң„ (-99999~99999). \\n\";
    dynAppend(dyn_error_msg,err_msg);
  }

/////////////////////////////Damper open time set

  float opentimeset_val1;

  getValue(OBJ_AD_OPEN_TM_SET,\"text\",opentimeset_val1);

  if(0 > opentimeset_val1 || opentimeset_val1 > 99999)
  {
    err_msg = \"м ңм•ҪмЎ°кұҙмң„л°ҳ: Damper Open Time лІ”мң„ (0~99999). \\n\";
    dynAppend(dyn_error_msg,err_msg);
  }

/////////////////////////////Damper open Limit

  float open_val1;

  getValue(OBJ_AD_OPEN_LM,\"text\",open_val1);

  if(0 > open_val1 || open_val1 > 100)
  {
    err_msg = \"м ңм•ҪмЎ°кұҙмң„л°ҳ: Damper Open Limet лІ”мң„ (0~100). \\n\";
    dynAppend(dyn_error_msg,err_msg);
  }

/////////////////////////////MIN & MAX

  float pressset_val1, get_max_val1, get_min_val1;

  getValue(OBJ_PRESS_SET1,\"text\",pressset_val1);

  getValue(OBJ_PRESS_SET1_MAX,\"text\",get_max_val1);
  getValue(OBJ_PRESS_SET1_MIN,\"text\",get_min_val1);

  if(get_max_val1<get_min_val1)
  {
    err_msg = \"м ңм•ҪмЎ°кұҙмң„л°ҳ: Min к°’мқҙ Max к°’ліҙлӢӨ нҒҪлӢҲлӢӨ. \\n\";
    dynAppend(dyn_error_msg,err_msg);
  }

   if(pressset_val1 > get_max_val1)
  {
    err_msg = \"м ңм•ҪмЎ°кұҙмң„л°ҳ: м„Өм •м••л Ҙ к°’мқҙ Max к°’ліҙлӢӨ нҒҪлӢҲлӢӨ. \\n\";
    dynAppend(dyn_error_msg,err_msg);
  }

   if(pressset_val1 < get_min_val1)
  {
    err_msg = \"м ңм•ҪмЎ°кұҙмң„л°ҳ: м„Өм •м••л Ҙ к°’мқҙ Min к°’ліҙлӢӨ мһ‘мҠөлӢҲлӢӨ. \\n\";
    dynAppend(dyn_error_msg,err_msg);
  }

  if(get_max_val1==get_min_val1)
  {
    err_msg = \"м ңм•ҪмЎ°кұҙмң„л°ҳ: Min к°’кіј Max к°’мқҙ к°ҷмҠөлӢҲлӢӨ. \\n\";
    dynAppend(dyn_error_msg,err_msg);
  }


  if(-99999 > get_max_val1 || get_max_val1 > 99999)
  {
    err_msg = \"м ңм•ҪмЎ°кұҙмң„л°ҳ: Max к°’ лІ”мң„ (-99999~99999). \\n\";
    dynAppend(dyn_error_msg,err_msg);
  }


  if(-99999 > get_min_val1 || get_min_val1 > 99999)
  {
    err_msg = \"м ңм•ҪмЎ°кұҙмң„л°ҳ: Min к°’ лІ”мң„ (-99999~99999). \\n\";
    dynAppend(dyn_error_msg,err_msg);
  }


  if(-99999 > pressset_val1 || pressset_val1 > 99999)
  {
    err_msg = \"м ңм•ҪмЎ°кұҙмң„л°ҳ: м„Өм •м••л Ҙ лІ”мң„ (-99999~99999). \\n\";
    dynAppend(dyn_error_msg,err_msg);
  }

//////////////////////////////////////////////////////////////////////////////////////

    dpGet($SetDP + \".cmd.START_BIT\",bitstart);
    dpGet($SetDP + \".cmd.HOLD_BIT\",bithold);
    dpGet($SetDP + \".cmd.ALMRESET_BIT\",bitalmreset);
    dpGet($SetDP + \".cmd.CANCEL_BIT\",bitcancel);
    dpGet($SetDP + \".cmd.AB_START\",abstart);

    if(bitstart != abstart)
    {
      string textmsg;

      if(abstart)
        textmsg = \"AutoBackup Logicмқ„ м •м§Җн•ҳмӢңкІ мҠөлӢҲк№Ң?\";
      else
        textmsg = \"AutoBackup Logicмқ„ мӢңмһ‘н•ҳмӢңкІ мҠөлӢҲк№Ң?\";

      ChildPanelOnCentralModalReturn(\"general/popup/message/POP_MESSAGE_A.pnl\",\"Control\",
                               makeDynString(\"$text:\"+textmsg),dreturnf,dreturns);

      if(dreturns==\"TRUE\")
      {
        if(abstart)
          dpSet($SetDP + \".cmd.AB_START\",false);
        else
          dpSet($SetDP + \".cmd.AB_START\",true);
      }

       dpSet($SetDP + \".cmd.START_BIT\",0);
    }

    if(bithold)
    {
      ChildPanelOnCentralModalReturn(\"general/popup/message/POP_MESSAGE_A.pnl\",\"Control\",
                               makeDynString(\"$text:\"+\"AutoBackup мғҒнғңк°Җ мң м§Җлҗ©лӢҲлӢӨ. \\nAutoBackup HoldлҘј reset н•ҳмӢңкІ мҠөлӢҲк№Ң?\"),dreturnf,dreturns);

      if(dreturns==\"TRUE\")
        dpSet($SetDP + \".cmd.HOLD_RESET\",1);

      dpSet($SetDP + \".cmd.HOLD_BIT\",0);
    }

    if(bitalmreset)
    {
      ChildPanelOnCentralModalReturn(\"general/popup/message/POP_MESSAGE_A.pnl\",\"Control\",
                               makeDynString(\"$text:\"+\"AutoBackup Alarmмқ„ reset н•ҳмӢңкІ мҠөлӢҲк№Ң?\"),dreturnf,dreturns);

      if(dreturns==\"TRUE\")
        dpSet($SetDP + \".cmd.AL_RESET\",1);

      dpSet($SetDP + \".cmd.ALMRESET_BIT\",0);
    }

    if(bitcancel)
    {
      ChildPanelOnCentralModalReturn(\"general/popup/message/POP_MESSAGE_A.pnl\",\"Control\",
                               makeDynString(\"$text:\"+\"AutoBackup Logicмқ„ м·ЁмҶҢн•ҳкІ мҠөлӢҲк№Ң?\"),dreturnf,dreturns);

      if(dreturns==\"TRUE\")
        dpSet($SetDP + \".cmd.CANCEL\",1);

      dpSet($SetDP + \".cmd.CANCEL_BIT\",0);
    }


//////////////////////////////////////



    // м •мғҒмғҒнғң ліҖкІҪк°’ м Ғмҡ©
    if(dynlen(dyn_error_msg) == 0)
    {
      APPLY_ACTION_BTN(POPUP_MSG_FILENAME,DYN_ALL_MAP_EDITABLE_DESC,
                     DYN_ALL_MAP_EDITABLE_KEYS,DYN_ALL_MAP_EDITABLE_VALUES,
                     mappingKeys(MAP_ALERT_PRIO),DYN_ALL_INIT_INVISIBLE);

      exception_apply();
    }


////////////////////////////////////////////////
//      м ңм•ҪмЎ°кұҙ мң„л°ҳмқҳ кІҪмҡ°
    else
    {
      for(int i=1;i<=dynlen(dyn_error_msg) ; i++)
      {
        all_err_msg += dyn_error_msg[i];
      }

        ChildPanelOnCentralModal(POPUP_ERR_MSG_FILENAME,\"err\",
               makeDynString(\"$text:\"+all_err_msg));
        PARAMETER_WINDOW_INITIAL(myModuleName(),myPanelName(),
                                 DYN_ALL_MAP_EDITABLE_KEYS,DYN_ALL_MAP_EDITABLE_VALUES,
                                 mappingKeys(MAP_ALERT_PRIO),DYN_ALL_INIT_INVISIBLE);
    }
}

void exception_apply()
{
  dyn_bool cur_value;
  dyn_int cur_intvalue, result;
  dyn_float dreturnf;
  dyn_string dreturns,mode_string;
  int auto_val,man_val,result_tot;

  getValue(\"obj_auto_sel1\",\"state\",0,cur_value[1]);
  getValue(\"obj_auto_sel2\",\"state\",0,cur_value[2]);
  getValue(\"obj_auto_sel3\",\"state\",0,cur_value[3]);
  getValue(\"obj_auto_sel4\",\"state\",0,cur_value[4]);
  getValue(\"obj_auto_sel5\",\"state\",0,cur_value[5]);

  for( int i=1;i<=5;i++)
  {
    if(dp_value[i] !=  cur_value[i])
    {
      result[i] = 1;
    }
    else
    {
      result[i] = 0;
    }
  }

    result_tot = result[1] + result[2] + result[3] + result[4] + result[5];

    if(result_tot==1)
    {
      for( int i=1;i<=5;i++)
      {
      if(dp_value[i]==0 && cur_value[i]==1)
      {
        ChildPanelOnCentralModalReturn(POPUP_MSG_FILENAME,\"Chang Value\",
        makeDynString(\"$tagname:\"+ $SetDP ,\"$node_desc:\"+ i +\"нҳёкё° PRESS AUTO BACKUP\",\"$dp_value:\"+ dp_value[i],
                       \"$modified_value:\"+ cur_value[i]),dreturnf,dreturns);

         if(dreturns == \"TRUE\")
         {
            dpSet($SetDP  + \".cmd.AUTOSEL.SEL\"+i,TRUE);

            USERTRAIL_APP($SetDP,\"SELECT\"+i,dp_value[i],TRUE);
         }
        }
         else  if(dp_value[i]==1 && cur_value[i]==0)
        {
           ChildPanelOnCentralModalReturn(POPUP_MSG_FILENAME,\"Chang Value\",
        makeDynString(\"$tagname:\"+ $SetDP ,\"$node_desc:\"+ i +\"нҳёкё° PRESS AUTO BACKUP\",\"$dp_value:\"+ dp_value[i],
                       \"$modified_value:\"+ cur_value[i]),dreturnf,dreturns);

         if(dreturns == \"TRUE\")
         {
            dpSet($SetDP  + \".cmd.AUTOSEL.SEL\"+i,false);

            USERTRAIL_APP($SetDP,\"SELECT\"+i,dp_value[i],false);
         }
         }
      }
    }
     else if(result_tot==2)
     {
       for( int i=1;i<=5;i++)
       {
         if(dp_value[i]==0 && cur_value[i]==1)
        {
        ChildPanelOnCentralModalReturn(POPUP_MSG_FILENAME,\"Chang Value\",
        makeDynString(\"$tagname:\"+ $SetDP ,\"$node_desc:\"+ i +\"нҳёкё° PRESS AUTO BACKUP\",\"$dp_value:\"+ dp_value[i],
                       \"$modified_value:\"+ cur_value[i]),dreturnf,dreturns);

         if(dreturns == \"TRUE\")
         {
            dpSet($SetDP  + \".cmd.AUTOSEL.SEL1\",cur_value[1]);
            dpSet($SetDP  + \".cmd.AUTOSEL.SEL2\",cur_value[2]);
            dpSet($SetDP  + \".cmd.AUTOSEL.SEL3\",cur_value[3]);
            dpSet($SetDP  + \".cmd.AUTOSEL.SEL4\",cur_value[4]);
            dpSet($SetDP  + \".cmd.AUTOSEL.SEL5\",cur_value[5]);

            USERTRAIL_APP($SetDP,\"SELECT\"+i,dp_value[i],TRUE);
         }
        }
       }
     }
    Func_MODE_INI();

}
