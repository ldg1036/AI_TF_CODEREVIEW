"main()
{
  EP_setBackColor();
}

EP_setBackColor()
{
dyn_errClass err;

  if(!dpExists($SetDP + \".alert.AB_TOTAL_ALARM_1\") ||
     !dpExists($SetDP + \".alert.AB_TOTAL_ALARM_2\") ||
     !dpExists($SetDP + \".alert.AB_TOTAL_ALARM_3\") ||
     !dpExists($SetDP + \".alert.AB_TOTAL_ALARM_4\") ||
     !dpExists($SetDP + \".alert.AB_TOTAL_ALARM_5\") ||
     !dpExists($SetDP + \".cmd.ALMRESET_BIT\"))
  {
    setValue(\"\", \"color\", \"_dpdoesnotexist\");
    return;
  }

  dpSet($SetDP + \".cmd.ALMRESET_BIT\",false);

  dpConnect(\"EP_setBackColorCB\",
            $SetDP + \".alert.AB_TOTAL_ALARM_1\",
            $SetDP + \".alert.AB_TOTAL_ALARM_2\",
            $SetDP + \".alert.AB_TOTAL_ALARM_3\",
            $SetDP + \".alert.AB_TOTAL_ALARM_4\",
            $SetDP + \".alert.AB_TOTAL_ALARM_5\",
            $SetDP + \".cmd.ALMRESET_BIT\");

  err = getLastError();
  if (dynlen(err) > 0)
    setValue(\"\", \"color\", \"_dpdoesnotexist\");

}

EP_setBackColorCB(string dp1, bool alarm1, string dp2, bool alarm2, string dp3, bool alarm3, string dp4, bool alarm4, string dp5, bool alarm5, string dp6, bool alarmbit)
{
  int total = 0;

  if(alarm1)
    total += 1;

  if(alarm2)
    total += 1;

  if(alarm3)
    total += 1;

  if(alarm4)
    total += 1;

  if(alarm5)
    total += 1;

  if (total == 0 && !alarmbit)
    setValue(\"\", \"backCol\", \"{255,207,48}\");
  else if (alarmbit)
    setValue(\"\", \"backCol\", \"<{0,255,0},4,{0,127,0},4>\");
  else
    setValue(\"\", \"backCol\", \"COR_ALM_EMER_UNACK\");
}







