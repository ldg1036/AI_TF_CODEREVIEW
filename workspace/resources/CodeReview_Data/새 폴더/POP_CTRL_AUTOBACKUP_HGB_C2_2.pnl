"main()
{
  dpConnect(\"CB_check_autoAB\",$SetDP + \".cmd.AUTOSEL.SEL1\");
  dpConnect(\"CB_check_autoAB\",$SetDP + \".cmd.AUTOSEL.SEL2\");
  dpConnect(\"CB_check_autoAB\",$SetDP + \".cmd.AUTOSEL.SEL3\");
  dpConnect(\"CB_check_autoAB\",$SetDP + \".cmd.AUTOSEL.SEL4\");
  dpConnect(\"CB_check_autoAB\",$SetDP + \".cmd.AUTOSEL.SEL5\");

}
CB_check_autoAB(string dp, bool value)
{

  bool value1,value2,value3,value4,value5;
  dyn_int tot_val;

  dpGet($SetDP + \".cmd.AUTOSEL.SEL1\",value1);
  dpGet($SetDP + \".cmd.AUTOSEL.SEL2\",value2);
  dpGet($SetDP + \".cmd.AUTOSEL.SEL3\",value3);
  dpGet($SetDP + \".cmd.AUTOSEL.SEL4\",value4);
  dpGet($SetDP + \".cmd.AUTOSEL.SEL5\",value5);

  tot_val=makeDynInt(value1,value2,value3,value4,value5);

//   tot_vol = value1+value2+value3+value4+value5;
//
//   DebugTN(\"11111111\",tot_val);


    if(dynSum(tot_val) != 0)
    {
      setValue(\"obj_sel_errorBX\",\"visible\",false);
      setValue(\"obj_sel_errorTX\",\"visible\",false);
      setValue(\"obj_sel_errorPB\",\"visible\",false);
    }
    else
    {
      setValue(\"obj_sel_errorBX\",\"visible\",true);
      setValue(\"obj_sel_errorTX\",\"visible\",true);
      setValue(\"obj_sel_errorPB\",\"visible\",true);
    }

}


