"main()
{

  windowStyle(myModuleName(),myPanelName(),0,0);  // popup ini мөңмҶҢнҷ” мӮӯм ң
  POP_DIFF_COL_MODE = true;


  dyn_errClass err;
  string a;

  MAPP(dyn_dp);

  string dp_press_set1 = MAP_EDITABLE_VALUE[OBJ_PRESS_SET1];

  string dp_press_set1_max = MAP_EDITABLE_VALUE[OBJ_PRESS_SET1_MAX];
  string dp_press_set1_min = MAP_EDITABLE_VALUE[OBJ_PRESS_SET1_MIN];

//   string dp_auto_sel1 = MAP_CHECK[OBJ_AUTO_SEL1];
//   string dp_auto_sel2 = MAP_CHECK[OBJ_AUTO_SEL2];
//   string dp_auto_sel3 = MAP_CHECK[OBJ_AUTO_SEL3];
//   string dp_auto_sel4 = MAP_CHECK[OBJ_AUTO_SEL4];
//   string dp_auto_sel5 = MAP_CHECK[OBJ_AUTO_SEL5];

//   dyn_string dpL_hang1_cx = MAP_VALUE_BOOL[OBJ_HANG1_CX];
//   dyn_string dpL_hang2_cx = MAP_VALUE_BOOL[OBJ_HANG2_CX];
//   dyn_string dpL_hang3_cx = MAP_VALUE_BOOL[OBJ_HANG3_CX];
//   dyn_string dpL_hang4_cx = MAP_VALUE_BOOL[OBJ_HANG4_CX];
//   dyn_string dpL_hang5_cx = MAP_VALUE_BOOL[OBJ_HANG5_CX];

  string dp_hz_set1 = MAP_EDITABLE_VALUE[OBJ_HZ_SET1];

  string dp_fan_vib_hilm = MAP_EDITABLE_VALUE[OBJ_FAN_VIB_HILM];

  string dp_ad_open_tm_set = MAP_EDITABLE_VALUE[OBJ_AD_OPEN_TM_SET];
  string dp_ad_open_tmlm = MAP_READONLY_VALUE[OBJ_AD_OPEN_TMLM];

  string dp_ad_open_lm = MAP_EDITABLE_VALUE[OBJ_AD_OPEN_LM];

//   string dp_obj_fan_check_dly_tm_set = MAP_READONLY_VALUE[OBJ_FAN_CHECK_DLY_TM_SET];
//   string dp_obj_fan_check_dly_tm = MAP_READONLY_VALUE[OBJ_FAN_CHECK_DLY_TM];

  string dp_fan_vib_invalidity = MAP_CHECK[OBJ_FAN_VIB_INVALIDITY];

///////////////////////////////////////////////////////////////////

  dpConnect(\"CB_value_textfield\",dp_press_set1);

  dpConnect(\"CB_value_textfield\",dp_press_set1_max);
  dpConnect(\"CB_value_textfield\",dp_press_set1_min);

  dpConnect(\"CB_check_box\",$SetDP + \".cmd.AUTOSEL.SEL1\",$SetDP + \".cmd.AUTOSEL.SEL2\",$SetDP + \".cmd.AUTOSEL.SEL3\",$SetDP + \".cmd.AUTOSEL.SEL4\",$SetDP + \".cmd.AUTOSEL.SEL5\");
//   dpConnect(\"CB_check_box\",$SetDP + \".cmd.AUTOSEL.SEL2\");
//   dpConnect(\"CB_check_box\",$SetDP + \".cmd.AUTOSEL.SEL3\");
//   dpConnect(\"CB_check_box\",$SetDP + \".cmd.AUTOSEL.SEL4\");
//   dpConnect(\"CB_check_box\",$SetDP + \".cmd.AUTOSEL.SEL5\");

//   dpConnect(\"CB_value_ractangle_sp\",dpL_hang1_cx);
//   dpConnect(\"CB_value_ractangle_sp\",dpL_hang2_cx);
//   dpConnect(\"CB_value_ractangle_sp\",dpL_hang3_cx);
//   dpConnect(\"CB_value_ractangle_sp\",dpL_hang4_cx);
//   dpConnect(\"CB_value_ractangle_sp\",dpL_hang5_cx);

  dpConnect(\"CB_value_textfield\",dp_hz_set1);

  dpConnect(\"CB_value_textfield\",dp_fan_vib_hilm);

  dpConnect(\"CB_value_textfield\",dp_ad_open_tm_set);
  dpConnect(\"CB_value_textfield\",dp_ad_open_tmlm);
  dpConnect(\"CB_value_textfield\",dp_ad_open_lm);

//   dpConnect(\"CB_value_textfield\",dp_obj_fan_check_dly_tm_set);
//   dpConnect(\"CB_value_textfield\",dp_obj_fan_check_dly_tm);

  dpConnect(\"CB_value_check_box\",dp_fan_vib_invalidity);


///////////////////////////////////////////////////////////////////

  err = getLastError();
  if (dynlen(err) > 0)
    DebugN(\"Erro:\",err);


  PARAMETER_WINDOW_INITIAL(myModuleName(),myPanelName(),DYN_ALL_MAP_EDITABLE_KEYS,
                          DYN_ALL_MAP_EDITABLE_VALUES,mappingKeys(MAP_ALERT_PRIO),
                          DYN_ALL_INIT_INVISIBLE);



}


