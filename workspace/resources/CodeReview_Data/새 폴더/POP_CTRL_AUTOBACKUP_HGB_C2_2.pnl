"main()
{
  EP_setBackColor();
}

EP_setBackColor()
{
dyn_errClass err;

  if( !dpExists($SetDP + \".alert.PROCESS_HOLD:_online.._value\") ||
      !dpExists($SetDP + \".cmd.HOLD_BIT\"))
  {
    setValue(\"\", \"color\", \"_dpdoesnotexist\");
    return;
  }

  dpSet($SetDP + \".cmd.HOLD_BIT\",false);

  dpConnect(\"EP_setBackColorCB\", 
            $SetDP + \".alert.PROCESS_HOLD:_online.._value\",
            $SetDP + \".cmd.HOLD_BIT\");
  err = getLastError();
  if (dynlen(err) > 0)
    setValue(\"\", \"color\", \"_dpdoesnotexist\");

}

EP_setBackColorCB(string dpSource, bool boNewValue, string dp, bool holdbit)
{
  if (!boNewValue && !holdbit)
    setValue(\"\", \"backCol\", \"{255,207,48}\");
  else if(holdbit)
    setValue(\"\", \"backCol\", \"<{0,255,0},4,{0,127,0},4>\");
  else
    setValue(\"\", \"backCol\", \"COR_ALM_BLOCK_SAFE\");
}


