E "main()
{
  bool bIsEdit;
  getValue(\"edit_button_press\",\"visible\",bIsEdit);
  if(!bIsEdit)
  {
    int EndInit = 2;     //мқҙмғҒмў…лЈҢм—җ лҢҖл№„н•ҙ мҙҲкё°к°’мқ„ errorлЎң м„ м–ё
    if(endOfMapp)     //MAPP н•ЁмҲҳк°Җ лҒқлӮң кІҪмҡ° м •н•©м„ұ check
    {
      EndInit = checkEndOfInitial(DYN_ALL_MAP_EDITABLE_VALUES,
      MAP_EDITABLE_VALUE, MAP_EDITABLE_ALM, MAP_ALERT_COMBO_PRIO,
      MAP_RADIO, MAP_CHECK, MAP_READONLY_VALUE);
        if(EndInit == 1)     //Initailмқҙ лҒқлӮҳм§Җ м•Ҡмңјл©ҙ Popupм°Ҫ нӣ„ return
      {
        ChildPanelOnCentralModal(POPUP_ERR_MSG_FILENAME,\"err\",
        makeDynString(\"$text:\"+\"к°’мқ„ мқҪлҠ” мӨ‘мһ…лӢҲлӢӨ. мһ мӢңнӣ„ лӢӨмӢң мӢңлҸ„н•ҳм„ёмҡ”.\"));
        return;
      }else if(EndInit == 2)     //ServerмҷҖ нҶөмӢ лӢЁм Ҳ. Popupм°Ҫ нӣ„ return
      {
        ChildPanelOnCentralModal(POPUP_ERR_MSG_FILENAME,\"err\",
        makeDynString(\"$text:\"+\"м„ңлІ„мҷҖ м—°кІ°мқҙ лӢЁм Ҳлҗң мғҒнғңмһ…лӢҲлӢӨ.\\nкі„мҶҚ м—°кІ°лҗҳм§Җ м•Ҡмңјл©ҙ ClientлҘј лӢӨмӢң мӢңмһ‘н•ҙ мЈјм„ёмҡ”.\"));
        return;
      }
    }else{      //MAPP н•ЁмҲҳк°Җ лҒқлӮҳм§Җ м•ҠмқҖ кІҪмҡ° Popupм°Ҫ нӣ„ return
      ChildPanelOnCentralModal(POPUP_ERR_MSG_FILENAME,\"err\",
      makeDynString(\"$text:\"+\"к°’мқ„ мқҪлҠ” мӨ‘мһ…лӢҲлӢӨ. мһ мӢңнӣ„ лӢӨмӢң мӢңлҸ„н•ҳм„ёмҡ”.\"));
      return;
    }
 }



  if (user_permission < 5)
  {

    if(mod_text.text==\"мҲҳм •\")
    {
//       getValue(\"edit_button_press\",\"visible\",bIsEdit);
      setValue(\"edit_button_press\",\"visible\",!bIsEdit);
      MODIFY_ACTION_BTN(myModuleName(),myPanelName(),
                    MAP_DEPEND_VALUE,DYN_ALL_MAP_EDITABLE_KEYS,
                    DYN_ALL_MAP_EDITABLE_VALUES,mappingKeys(MAP_ALERT_PRIO),
                    DYN_ALL_INIT_INVISIBLE,!bIsEdit);


      exception_modify();
     dpSet($SetDP + \".cmd.CANCEL_BIT\",false);
     dpSet($SetDP + \".cmd.ALMRESET_BIT\",false);
     dpSet($SetDP + \".cmd.HOLD_BIT\",false);
    }
  }
  else if (user_permission == 5)
  {
    ChildPanelOnCentral(\"general/popup/login/POP_LOGIN.pnl\",\"\",makeDynString());
  }
}

void exception_modify()
{

  bool bool_enabled;

//     check box enabled мғҒнғң trueлЎң ліҖкІҪ
    getValue(\"obj_auto_sel1\",\"enabled\",bool_enabled);
    setValue(\"obj_auto_sel1\",\"enabled\",!bool_enabled);
    getValue(\"obj_auto_sel2\",\"enabled\",bool_enabled);
    setValue(\"obj_auto_sel2\",\"enabled\",!bool_enabled);
    getValue(\"obj_auto_sel3\",\"enabled\",bool_enabled);
    setValue(\"obj_auto_sel3\",\"enabled\",!bool_enabled);
    getValue(\"obj_auto_sel4\",\"enabled\",bool_enabled);
    setValue(\"obj_auto_sel4\",\"enabled\",!bool_enabled);
    getValue(\"obj_auto_sel5\",\"enabled\",bool_enabled);
    setValue(\"obj_auto_sel5\",\"enabled\",!bool_enabled);

    if (!bool_enabled)
    {
      setValue(\"obj_auto_sel1\",\"foreCol\",\"White\");
      setValue(\"obj_auto_sel2\",\"foreCol\",\"White\");
      setValue(\"obj_auto_sel3\",\"foreCol\",\"White\");
      setValue(\"obj_auto_sel4\",\"foreCol\",\"White\");
      setValue(\"obj_auto_sel5\",\"foreCol\",\"White\");
    }
    else
    {
      Func_MODE_INI();
    }
 }
