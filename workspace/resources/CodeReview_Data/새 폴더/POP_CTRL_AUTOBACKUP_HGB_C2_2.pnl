 E "main()
{
    string all_err_msg;
    bool chk_err = 0;
    float newText;
    
    getValue(\"\",\"text\",newText);
  
    if (EDITMODE)
    {    
      if (newText < -99999)
      {
        all_err_msg = \"м„Өм • к°’мқҙ мһ‘мҠөлӢҲлӢӨ.  (мөңмҶҢ к°’ : -99999)\";
        chk_err = 1;
      }
      else if (newText > 99999)
      {
        all_err_msg = \"м„Өм • к°’мқҙ нҒҪлӢҲлӢӨ.  (мөңлҢҖ к°’ : 99999)\";
        chk_err = 1;
      }
      if(chk_err)
      {
        ChildPanelOnCentralModal(POPUP_ERR_MSG_FILENAME,\"err\",
                                 makeDynString(\"$text:\"+all_err_msg));
        this.text(newText);
      }
    }
}" 0

