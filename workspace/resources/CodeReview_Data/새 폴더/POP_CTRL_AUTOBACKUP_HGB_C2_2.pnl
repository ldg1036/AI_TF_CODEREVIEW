"main()
{
  EP_setBackColor();
}

EP_setBackColor()
{
dyn_errClass err;

  if( !dpExists($SetDP + \".cmd.CANCEL_BIT\"))
  {
    setValue(\"\", \"color\", \"_dpdoesnotexist\");
    return;
  }

  dpSet($SetDP + \".cmd.CANCEL_BIT\",false);

  dpConnect(\"EP_setBackColorCB\", 
            $SetDP + \".cmd.CANCEL_BIT\");
  err = getLastError();
  if (dynlen(err) > 0)
    setValue(\"\", \"color\", \"_dpdoesnotexist\");

}

EP_setBackColorCB(string dp1, bool value1)
{
  if (!value1)
    setValue(\"\", \"backCol\", \"{255,207,48}\");
  else
    setValue(\"\", \"backCol\", \"<{0,255,0},4,{0,127,0},4>\");
}

