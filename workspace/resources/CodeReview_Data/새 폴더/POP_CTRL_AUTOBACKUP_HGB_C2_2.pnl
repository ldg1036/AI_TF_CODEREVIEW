"// SimpleCtrlScriptStart {invalid}
main()
{
  EP_setBackColor();
}

EP_setBackColor()
{
dyn_errClass err;

  if( !dpExists(  $SetDP + \".alert.SET_AL_2\"))
  {
    setValue(\"\", \"color\", \"_dpdoesnotexist\");
    return;
  }
    
  dpConnect(\"EP_setBackColorCB\", 
