{
  string err_msg,all_err_msg;
  bool ST1,LOOP1,TOT1;
  float PV1;
  dyn_string dyn_error_msg;

  dpGet(\"C1_HVAC:T1_HGB_C2701D_ZV.PVLAST\",ST1);
  dpGet(\"C1_HVAC:T1_DPT_C2HG01NLOGIC.alert.LOOPERR\",LOOP1);
  dpGet(\"C1_HVAC:T1_HGB_C2701D_MVD_I.PVLAST\",PV1);
  dpGet(\"C1_HVAC:T1_HGB_C2701D_MVD_TOT.PVLAST\",TOT1);

  if(ST1 == 1 || LOOP1 == 1 || PV1 > 1 || TOT1== 1 )
  {
    err_msg = \"4нҳёкё° Ready мЎ°кұҙмқҙ лҗҳм–ҙм•ј н•©лӢҲлӢӨ  \\n\";
    dynAppend(dyn_error_msg,err_msg);
    setValue(\"obj_auto_sel4\",\"state\",0,false);
  }
  else
  {
    setValue(\"obj_auto_sel1\",\"state\",0,false);
    setValue(\"obj_auto_sel2\",\"state\",0,false);
    setValue(\"obj_auto_sel3\",\"state\",0,false);
    setValue(\"obj_auto_sel5\",\"state\",0,false);
  }
  if(dynlen(dyn_error_msg) > 0)
  {
    for(int i=1;i<=dynlen(dyn_error_msg) ; i++)
        {
          all_err_msg += dyn_error_msg[i];
        }

    ChildPanelOnCentralModal(POPUP_ERR_MSG_FILENAME,\"err\",
                             makeDynString(\"$text:\"+all_err_msg));
  }
}
