"main()
{
  dpConnect(\"CB_user_reverse_check_box\", $DP3 + \".cmd.ORP_USE\");
}

void CB_user_reverse_check_box(string dp, bool new_value)
{
  if(new_value == 1)
    this.state(0,1);
  else
    this.state(0,0);
}

