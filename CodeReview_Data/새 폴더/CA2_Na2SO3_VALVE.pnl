E "main()
{
  if (user_permission < 5){
    if(mod_text.text==\"ņłśņĀĢ\"){

      MODIFY_ACTION_BTN(myModuleName(),myPanelName(),
                        MAP_DEPEND_VALUE,DYN_ALL_MAP_EDITABLE_KEYS,
                        DYN_ALL_MAP_EDITABLE_VALUES,mappingKeys(MAP_ALERT_PRIO),
                        DYN_ALL_INIT_INVISIBLE);
      }
    
  }else if (user_permission == 5)
  {
   ChildPanelOn(\"vision/login.pnl\",
      \"\",
      makeDynString(),650,150);
  }
  
  if(EDITMODE)
  {
    bool check_tmp1;

    getValue(\"CHECK_BOX_R1\",\"state\",0,check_tmp1);
    
    setMultiValue(\"CHECK_BOX1\",\"state\",0,check_tmp1,
                  \"CHECK_BOX1\",\"visible\",true,
                  \"CHECK_BOX_R1\",\"visible\",false);
  }
  else
  {
    setMultiValue(\"CHECK_BOX1\",\"visible\",false,
                  \"CHECK_BOX_R1\",\"visible\",true);
  }
}



