"main()
{
  dyn_errClass err;

  MAPP();

  PARAMETER_WINDOW_INITIAL(myModuleName(),myPanelName(),
                           DYN_ALL_MAP_EDITABLE_KEYS,DYN_ALL_MAP_EDITABLE_VALUES,
                           mappingKeys(MAP_ALERT_PRIO),DYN_ALL_INIT_INVISIBLE);
  
  string obj_delaysp = MAP_EDITABLE_VALUE[OBJ_DELAYSP];
  string obj_interlocksp = MAP_EDITABLE_VALUE[OBJ_INTERLOCKSP];
  string obj_interlockdbsp = MAP_EDITABLE_VALUE[OBJ_INTERLOCKDBSP];
  string obj_closesp = MAP_EDITABLE_VALUE[OBJ_CLOSESP];
  string obj_deadbandsp = MAP_EDITABLE_VALUE[OBJ_DEADBANDSP];
  string obj_openvvsp = MAP_EDITABLE_VALUE[OBJ_OPENVVSP];
  string obj_closevvsp = MAP_EDITABLE_VALUE[OBJ_CLOSEVVSP];
  string obj_minvvsp = MAP_EDITABLE_VALUE[OBJ_MINVVSP];
  string obj_assset = MAP_EDITABLE_VALUE[OBJ_ASSSET];
  string dp_lastval = MAP_READONLY_VALUE[OBJ_LASTVAL];
  string dp_orplastval = MAP_READONLY_VALUE[OBJ_ORPLASTVAL];
  string obj_orpsp = MAP_READONLY_VALUE[OBJ_ORPSP];
  string dp_select1 = MAP_CHECK[OBJ_SELECT1];

  dpConnect(\"CB_value_textfield_dpid\", obj_delaysp);
  dpConnect(\"CB_value_textfield_dpid\", obj_interlocksp);
  dpConnect(\"CB_value_textfield_dpid\", obj_interlockdbsp);
  dpConnect(\"CB_value_textfield_dpid\", obj_closesp);
  dpConnect(\"CB_value_textfield_dpid\", obj_deadbandsp);
  dpConnect(\"CB_value_textfield_dpid\", obj_openvvsp);
  dpConnect(\"CB_value_textfield_dpid\", obj_closevvsp);
  dpConnect(\"CB_value_textfield_dpid\", obj_minvvsp);
  dpConnect(\"CB_value_textfield_dpid\", obj_assset);
  dpConnect(\"CB_value_textfield_dpid\", dp_lastval);
  dpConnect(\"CB_value_textfield_dpid\", dp_orplastval);
  dpConnect(\"CB_value_textfield_dpid\", obj_orpsp);
  dpConnect(\"CB_value_check_box_sp\", dp_select1);
  
  dpConnect(\"mode_change\",$DP3 + \".value.ORP_MODE_RESULT\");
  
  err = getLastError();
  if (dynlen(err) > 0)
    DebugN(\"Erro:\",err);
}

void mode_change(string dp, bool mode)
{
  if(mode)
  {
    setMultiValue(\"bg_PID\", \"backCol\", \"{166,166,166}\",
                  \"line_PID\", \"visible\", FALSE,
                  \"bg_ORP\", \"backCol\", \"STD_value_invalid\",
                  \"line_ORP\", \"visible\", TRUE);
  }
  else
  {
    setMultiValue(\"bg_PID\", \"backCol\", \"STD_value_invalid\",
                  \"line_PID\", \"visible\", TRUE,
                  \"bg_ORP\", \"backCol\", \"{166,166,166}\",
                  \"line_ORP\", \"visible\", FALSE);
  }
}




