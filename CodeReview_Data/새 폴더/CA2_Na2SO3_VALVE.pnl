""0  1
E "
string OBJ_ORPSP = \"obj_orpsp\";
string OBJ_DELAYSP = \"obj_delaysp\";
string OBJ_INTERLOCKSP = \"obj_interlocksp\";
string OBJ_INTERLOCKDBSP = \"obj_interlockdbsp\";
string OBJ_CLOSESP = \"obj_closesp\";
string OBJ_DEADBANDSP = \"obj_deadbandsp\";
string OBJ_OPENVVSP = \"obj_openvvsp\";
string OBJ_CLOSEVVSP = \"obj_closevvsp\";
string OBJ_MINVVSP = \"obj_minvvsp\";
string OBJ_ASSSET = \"obj_assset\";
string OBJ_MODE = \"obj_mode\";
string OBJ_LASTVAL = \"obj_lastval\";
string OBJ_ORPLASTVAL = \"obj_orplastval\";
string OBJ_SELECT1 = \"CHECK_BOX1\";


dyn_string DYN_ALL_MAP_EDITABLE_VALUES; // DP ELEMENT Ļ░Æ EX: TI_001A.CMD.PVSOURCE -  EDIT Ļ░ĆļŖź ņåŹņä▒ - ļ░░ņŚ┤ņĀĆņ×ź
dyn_string DYN_ALL_MAP_EDITABLE_KEYS;  // DPE Object Name - ļ░░ņŚ┤ņĀĆņ×ź
dyn_string DYN_ALL_MAP_EDITABLE_DESC;  // MSG BOX DESCRIPTION - TEXT OBJ - ļ░░ņŚ┤ņĀĆņ×ź
dyn_string DYN_ALL_INIT_INVISIBLE;  // COMBO BOX INVISIBLE - ļ░░ņŚ┤ņĀĆņ×ź

mapping MAP_SHAPE_TYPE;  // ĒÖöļ®┤  object type ļ¬ģĻĖ░ (ex : text, combo box, radio box .... ļō▒ļō▒)
mapping MAP_EDITABLE_ALM;  // ALARM VALUE DPE ņ¦ĆņĀĢ
mapping MAP_EDITABLE_VALUE;  // TEXT OBJ  DPE ņ¦ĆņĀĢ
mapping MAP_ALERT_BOOL;  // BIT TYPE ALARM DPE ņ¦ĆņĀĢ
mapping MAP_READONLY_VALUE;  // READ ONLY DPE ņ¦ĆņĀĢ
mapping MAP_ALERT_PRIO;  // CASCADE OBJ - ALARM PRIO DPE ņ¦ĆņĀĢ
mapping MAP_ALERT_COMBO_PRIO;  // COMBO BOX OBJ - ALARM PRIO DPE ņ¦ĆņĀĢ
mapping MAP_EDITABLE_DESC;  // DPE Object Name ņ¦ĆņĀĢ
mapping MAP_RADIO; // ņ×ģļĀź / ņä╝ņä£ĻĄ¼ļČä DPE ņ¦ĆņĀĢ
mapping MAP_CHECK; // CHECK BOX OBJECT DPE ņ¦ĆņĀĢ
mapping MAP_DEPEND_VALUE;  //ņØśņĪ┤ņä▒ņØ┤ ņ×łļŖö Ļ▓ĮņÜ░ : ņłśļÅÖ ļ¬©ļō£ ņØ╝ļĢī ņłśļÅÖĻ░Æ ĒĢäļō£Ļ░Ć ONļÉśļŖö Ļ▓ĮņÜ░
mapping MAP_VALUE_BOOL;  // BIT TYPE VALUE DPE ņ¦ĆņĀĢ

void MAPP()
{
  string caption, PTS;

  MAP_SHAPE_TYPE[\"TEXT_FIELD\"] = 1;
  MAP_SHAPE_TYPE[\"COMBO_BOX\"] = 2;
  MAP_SHAPE_TYPE[\"RADIO_BOX\"] = 3;
  MAP_SHAPE_TYPE[\"CASCADE_BOX\"] = 4;
  MAP_SHAPE_TYPE[\"CHECK_BOX\"] = 5;
  
// **************************************** check box ***************************************************
  
  MAP_CHECK[OBJ_SELECT1] = $DP3 + \".cmd.ORP_USE\";
  MAP_EDITABLE_DESC[OBJ_SELECT1] = \"ORP ņĀ£ņ¢┤ ņé¼ņÜ® ņŚ¼ļČĆ\";
  dynAppend(DYN_ALL_MAP_EDITABLE_KEYS,OBJ_SELECT1);  
  

// ****************************** text ****************************************
  
  MAP_EDITABLE_VALUE[OBJ_DELAYSP] = $DP3 + \".cmd.ORP_MODE_DELAY\";
//   getValue(\"text_pressdelay\",\"text\",caption);
  MAP_EDITABLE_DESC[OBJ_DELAYSP] = \"PID <-> ORP ļ¬©ļō£ ņĀäĒÖś Delay\";
  dynAppend(DYN_ALL_MAP_EDITABLE_KEYS,OBJ_DELAYSP);
  
  MAP_EDITABLE_VALUE[OBJ_INTERLOCKSP] = $DP3 + \".cmd.ORP_INTERLOCK_SP\";
//   getValue(\"text_pressdelay\",\"text\",caption);
  MAP_EDITABLE_DESC[OBJ_INTERLOCKSP] = \"ORP INTERLOCK ņäżņĀĢĻ░Æ\";
  dynAppend(DYN_ALL_MAP_EDITABLE_KEYS,OBJ_INTERLOCKSP);
  
  MAP_EDITABLE_VALUE[OBJ_INTERLOCKDBSP] = $DP3 + \".cmd.ORP_INTERLOCK_DB\";
//   getValue(\"text_pressdelay\",\"text\",caption);
  MAP_EDITABLE_DESC[OBJ_INTERLOCKDBSP] = \"ORP INTERLOCK DEADBAND\";
  dynAppend(DYN_ALL_MAP_EDITABLE_KEYS,OBJ_INTERLOCKDBSP);
  
  MAP_EDITABLE_VALUE[OBJ_CLOSESP] = $DP3 + \".cmd.ORP_CLOSE_RUN_SP\";
//   getValue(\"text_pressdelay\",\"text\",caption);
  MAP_EDITABLE_DESC[OBJ_CLOSESP] = \"ORP CLOSE ļÅÖņ×æ ņäżņĀĢĻ░Æ\";
  dynAppend(DYN_ALL_MAP_EDITABLE_KEYS,OBJ_CLOSESP);
  
  MAP_EDITABLE_VALUE[OBJ_DEADBANDSP] = $DP3 + \".cmd.ORP_CLOSE_DB\";
//   getValue(\"text_pressdelay\",\"text\",caption);
  MAP_EDITABLE_DESC[OBJ_DEADBANDSP] = \"ORP CLOSE ļÅÖņ×æ DEADBAND\";
  dynAppend(DYN_ALL_MAP_EDITABLE_KEYS,OBJ_DEADBANDSP);
  
  MAP_EDITABLE_VALUE[OBJ_OPENVVSP] = $DP3 + \".cmd.ORP_OPEN_SP\";
//   getValue(\"text_pressdelay\",\"text\",caption);
  MAP_EDITABLE_DESC[OBJ_OPENVVSP] = \"V/V OPEN Ļ░£ļÅä ņäżņĀĢĻ░Æ\";
  dynAppend(DYN_ALL_MAP_EDITABLE_KEYS,OBJ_OPENVVSP);
  
  MAP_EDITABLE_VALUE[OBJ_CLOSEVVSP] = $DP3 + \".cmd.ORP_CLOSE_SP\";
//   getValue(\"text_pressdelay\",\"text\",caption);
  MAP_EDITABLE_DESC[OBJ_CLOSEVVSP] = \"V/V CLOSE Ļ░£ļÅä ņäżņĀĢĻ░Æ\";
  dynAppend(DYN_ALL_MAP_EDITABLE_KEYS,OBJ_CLOSEVVSP);
  
  MAP_EDITABLE_VALUE[OBJ_MINVVSP] = $DP5 + \".cmd.LOLM_SP\";
//   getValue(\"main\",\"text\",caption);
  MAP_EDITABLE_DESC[OBJ_MINVVSP] = \"Na2SO3 V/V ņĄ£ņåīĻ░£ļÅä\";
  dynAppend(DYN_ALL_MAP_EDITABLE_KEYS,OBJ_MINVVSP);
  
  MAP_EDITABLE_VALUE[OBJ_ASSSET] = $DP6 + \".cmd.AMPLO_SP\";
//   getValue(\"text_pressset\",\"text\",caption);
  MAP_EDITABLE_DESC[OBJ_ASSSET] = \"FAN ņĀäļźśĒĢśĒĢ£ ņäżņĀĢĻ░Æ\";
  dynAppend(DYN_ALL_MAP_EDITABLE_KEYS,OBJ_ASSSET);
  
  
  //radio Ļ░Øņ▓┤    
  MAP_RADIO[OBJ_MODE] = $DP3 + \".cmd.ORP_INTERLOCK_USE\";
//   getValue(\"text_mode\",\"text\",caption);
  MAP_EDITABLE_DESC[OBJ_MODE] = \"ORP INTERLOCK ņé¼ņÜ®/ļ»Ėņé¼ņÜ®\";
  dynAppend(DYN_ALL_MAP_EDITABLE_KEYS,OBJ_MODE);
  
  // read only mapping
  MAP_READONLY_VALUE[OBJ_LASTVAL] = $DP1 + \"_SEL.value.PV_LAST\";
  MAP_READONLY_VALUE[OBJ_ORPLASTVAL] = $DP2 + \"_SEL.value.PV_LAST\";
  MAP_READONLY_VALUE[OBJ_ORPSP] = $DP3 + \".cmd.ORP_MODE_SP\";

  string map_value,map_key;
  bool bool_haskey;
  
  for(int i=1;i<=dynlen(DYN_ALL_MAP_EDITABLE_KEYS);i++)
  {
    map_key = DYN_ALL_MAP_EDITABLE_KEYS[i];
  //ņĢīļ×īņäżņĀĢ
    bool_haskey = mappingHasKey(MAP_EDITABLE_ALM,map_key);
  
    if(bool_haskey)
    {
      map_value = MAP_EDITABLE_ALM[map_key];
      dynAppend(DYN_ALL_MAP_EDITABLE_VALUES,map_value);
      dynAppend(DYN_ALL_MAP_EDITABLE_DESC,MAP_EDITABLE_DESC[map_key]);
      continue;
    }
    //ņĢīļ×ī PrioņäżņĀĢ
    bool_haskey = mappingHasKey(MAP_ALERT_COMBO_PRIO,map_key);
  
    if(bool_haskey)
    {
      map_value = MAP_ALERT_COMBO_PRIO[map_key];
      dynAppend(DYN_ALL_MAP_EDITABLE_VALUES,map_value);
      dynAppend(DYN_ALL_MAP_EDITABLE_DESC,MAP_EDITABLE_DESC[map_key]);
      continue;
    }
    //ĻĖ░ĒāĆ ņäżņĀĢĻ░Æ
    bool_haskey = mappingHasKey(MAP_EDITABLE_VALUE,map_key);    
    if(bool_haskey)
    {  
      map_value = MAP_EDITABLE_VALUE[map_key];
      dynAppend(DYN_ALL_MAP_EDITABLE_VALUES,map_value);
      dynAppend(DYN_ALL_MAP_EDITABLE_DESC,MAP_EDITABLE_DESC[map_key]);
      continue;
    }
    bool_haskey = mappingHasKey(MAP_ALERT_PRIO,map_key);    
    if(bool_haskey)
    {  
      map_value = MAP_ALERT_PRIO[map_key];
      dynAppend(DYN_ALL_MAP_EDITABLE_VALUES,map_value);
      dynAppend(DYN_ALL_MAP_EDITABLE_DESC,MAP_EDITABLE_DESC[map_key]);
      continue;
    }
    bool_haskey = mappingHasKey(MAP_RADIO,map_key);    
    if(bool_haskey)
    {  
      map_value = MAP_RADIO[map_key];
      dynAppend(DYN_ALL_MAP_EDITABLE_VALUES,map_value);
      dynAppend(DYN_ALL_MAP_EDITABLE_DESC,MAP_EDITABLE_DESC[map_key]);
      continue;
    }
    bool_haskey = mappingHasKey(MAP_CHECK,map_key);  
    if(bool_haskey)
    {  
      map_value = MAP_CHECK[map_key];
      dynAppend(DYN_ALL_MAP_EDITABLE_VALUES,map_value);
      dynAppend(DYN_ALL_MAP_EDITABLE_DESC,MAP_EDITABLE_DESC[map_key]);
      continue;
    }
  }  
}









