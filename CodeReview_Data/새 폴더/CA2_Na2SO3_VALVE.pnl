E "main()
{  
  string euhi,eulo,err_msg,all_err_msg;
  float dp_hh,dp_hi,dp_lo,dp_ll,alm_value,alm_chg_value;
  dyn_float dyn_dp_alm_value,dyn_cur_alm_value,dyn_chg_alm_value;
  dyn_string dyn_sort_cur_alm_value,dyn_obj,dyn_error_msg;
  int error_idx;
  mapping map_sort_alm_value;
  anytype tmp;

  float r_interlockdbsp;
  float r_deadbandsp;
  bool check_tmp1, check_tmp_R1;

  getMultiValue(\"obj_interlockdbsp\",\"text\",r_interlockdbsp,
                \"obj_deadbandsp\",\"text\",r_deadbandsp,
                \"CHECK_BOX_R1\",\"state\",0,check_tmp_R1,
                \"CHECK_BOX1\",\"state\",0,check_tmp1);
  
  if( r_interlockdbsp < 0 )
  {
    err_msg = \"ņĀ£ņĢĮņĪ░Ļ▒┤ ņ£äļ░ś: INTERLOCK DEADBAND ņäżņĀĢļ▓öņ£ä (0 ņØ┤ņāü)\\n\";
    dynAppend(dyn_error_msg,err_msg);
  }
  
  if( r_deadbandsp < 0 )
  {
    err_msg = \"ņĀ£ņĢĮņĪ░Ļ▒┤ ņ£äļ░ś: CLOSE DEADBAND ņäżņĀĢļ▓öņ£ä (0 ņØ┤ņāü)\\n\";
    dynAppend(dyn_error_msg,err_msg);
  }

  // ņĀĢņāüņāüĒā£ ļ│ĆĻ▓ĮĻ░Æ ņĀüņÜ®
  if(dynlen(dyn_error_msg) == 0)
    APPLY_ACTION_BTN_PP(POPUP_MSG_FILENAME,DYN_ALL_MAP_EDITABLE_DESC,
                   DYN_ALL_MAP_EDITABLE_KEYS,DYN_ALL_MAP_EDITABLE_VALUES,
                   mappingKeys(MAP_ALERT_PRIO),DYN_ALL_INIT_INVISIBLE);
  // ņĀ£ņĢĮņĪ░Ļ▒┤ ņ£äļ░śņØś Ļ▓ĮņÜ░
  else                        
  {
    for(int i=1;i<=dynlen(dyn_error_msg) ; i++)
    {
      all_err_msg += dyn_error_msg[i];
    }
    
      ChildPanelOnCentralModal(POPUP_ERR_MSG_FILENAME,\"err\",
             makeDynString(\"$text:\"+all_err_msg));
      PARAMETER_WINDOW_INITIAL(myModuleName(),myPanelName(),
                               DYN_ALL_MAP_EDITABLE_KEYS,DYN_ALL_MAP_EDITABLE_VALUES,
                               mappingKeys(MAP_ALERT_PRIO),DYN_ALL_INIT_INVISIBLE);
  }
  
  setMultiValue(\"CHECK_BOX1\",\"visible\",FALSE,
                \"CHECK_BOX_R1\",\"visible\",TRUE);
}


